# Normalize line endings to LF in the repository and on checkout.
#
# Without this, Windows checkouts (GitHub Actions sets core.autocrlf=true by
# default) rewrite committed files to CRLF, while the shared-contract generator
# writes LF — producing a false "Generated contract drift" failure in
# `npm run check:shared-contracts`. Pinning text files to LF keeps the generated
# contracts byte-identical across Linux/macOS/Windows.
* text=auto eol=lf

# Be explicit for the file types we generate, mirror, and validate.
*.json text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Treat binary assets as binary (never normalized).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
