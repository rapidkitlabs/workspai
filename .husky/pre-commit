#!/usr/bin/env sh

# Type checking
echo "🔍 Running type check..."
npm run typecheck || exit 1

# Linting
echo "🧹 Running linter..."
npx lint-staged || exit 1

# Format check
echo "💅 Checking code formatting..."
npm run format:check || exit 1

# Contracts sync check (only when Core schema is available)
if [ -n "${RAPIDKIT_CORE_SCHEMA_PATH:-}" ] && [ -f "${RAPIDKIT_CORE_SCHEMA_PATH}" ]; then
	echo "🔗 Checking Core ↔ NPM contracts..."
	npm run check:contracts || exit 1
elif [ -f "../core/docs/contracts/rapidkit-cli-contracts.json" ]; then
	echo "🔗 Checking Core ↔ NPM contracts (monorepo)..."
	RAPIDKIT_CORE_SCHEMA_PATH="../core/docs/contracts/rapidkit-cli-contracts.json" npm run check:contracts || exit 1
elif [ -f "../../core/docs/contracts/rapidkit-cli-contracts.json" ]; then
	echo "🔗 Checking Core ↔ NPM contracts (monorepo)..."
	RAPIDKIT_CORE_SCHEMA_PATH="../../core/docs/contracts/rapidkit-cli-contracts.json" npm run check:contracts || exit 1
else
	echo "ℹ️ Skipping contracts check (core schema not found)"
fi

# Shared contracts (canonical: rapidkit-npm/contracts/)
echo "📋 Validating shared contracts..."
npm run validate:contracts || {
	echo "❌ Contract validation failed."
	echo "   1. Change code or run: npm run generate:contracts"
	echo "   2. Run: npm run sync:parity-snapshot"
	echo "   3. Commit contracts/ in rapidkit-npm and rapidkit-vscode"
	exit 1
}

# Tests
echo "🧪 Running tests..."
npm test || exit 1

echo "✅ All checks passed!"
