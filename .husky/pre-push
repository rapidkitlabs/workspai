#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-push validation..."

# Run Prettier format check
echo "  → Checking code formatting..."
npm --workspace workspai run format:check || {
  echo "❌ Code formatting issues found. Run 'npm --workspace workspai run format' to fix."
  exit 1
}

# Run ESLint (errors only)
echo "  → Checking for lint errors..."
npm --workspace workspai run lint -- --quiet || {
  echo "❌ Lint errors found. Fix them before pushing."
  exit 1
}

# Run TypeScript type checking
echo "  → Running type checks..."
npm --workspace workspai run typecheck || {
  echo "❌ Type check failed. Fix type errors before pushing."
  exit 1
}

# Run tests
echo "  → Running tests..."
npm test || {
  echo "❌ Tests failed. Fix failing tests before pushing."
  exit 1
}

echo "✅ All pre-push checks passed!"
