{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "workspacePath",
    "mode",
    "summary",
    "stages",
    "blockingReasons",
    "nextActions",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": {
      "const": "autopilot-release-v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "workspacePath": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "audit",
        "safe-fix",
        "enforce"
      ]
    },
    "summary": {
      "type": "object"
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "blockingReasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
