{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "workspaceRoot",
    "status",
    "mode",
    "safety",
    "candidateTools"
  ],
  "properties": {
    "schemaVersion": {
      "const": "workspai-mcp-design.v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "workspaceRoot": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "const": "design-only"
    },
    "mode": {
      "const": "read-mostly"
    },
    "safety": {
      "type": "object"
    },
    "candidateTools": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
