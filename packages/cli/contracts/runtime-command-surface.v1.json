        "--json"
      ],
      "produces": [
        {
          "path": ".workspai/reports/doctor-last-run.json",
          "schemaVersion": "doctor-workspace-evidence-v1",
          "contractPath": "contracts/doctor-workspace-evidence.v1.json"
        }
      ]
    },
    {
      "id": "contract-evidence",
      "argv": [
        "workspace",
